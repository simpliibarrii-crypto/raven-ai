# openclinical-ai runtime — environment variables
# Copy this file to .env and adjust values for your environment.
# NEVER commit the .env file to version control.

# --- Runtime paths ---
# OPENCLINICAL_REGISTRY_PATH=/var/lib/openclinical/registry
# OPENCLINICAL_AUDIT_PATH=/var/lib/openclinical/audit
# OPENCLINICAL_CONSENT_PATH=/var/lib/openclinical/consent
# OPENCLINICAL_TENANTS_PATH=/var/lib/openclinical/tenants
# OPENCLINICAL_CAREPLANS_PATH=/var/lib/openclinical/careplans

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for development.
OPENCLINICAL_CORS_ORIGINS=http://localhost:8088

# --- Demo tenant API keys (dev only) ---
# These keys are ONLY for local development and testing.
# In production, tenant records are loaded from a secure database.
# OPENCLINICAL_DEMO_KEY_BAYSHORE=demo-bayshore-key
# OPENCLINICAL_DEMO_KEY_CAREFOR=demo-carefor-key
# OPENCLINICAL_DEMO_KEY_VHA=demo-vha-key
# OPENCLINICAL_DEMO_KEY_ARMSTRONG=demo-armstrong-key
# OPENCLINICAL_DEMO_KEY_TOH=demo-toh-key

# --- Environment ---
# Set to "production" to disable demo data seeding
# OPENCLINICAL_ENV=dev

# --- Logging ---
# LOG_LEVEL=INFO

# --- FHIR base URL (optional) ---
# OPENCLINICAL_FHIR_BASE_URL=
